# Copie este arquivo para `.env.local` e preencha os valores sem commitar segredos.

# Frontend
VITE_APP_TITLE="Criativa Field Ops"
VITE_API_BASE_URL="/api"
VITE_DEFAULT_INDUSTRIES="Veneza,Idealpan,Maricota,VidaVeg"

# Backend / Serverless
# Configure estes valores no ambiente do deploy ou em um arquivo separado do backend.
APP_SESSION_SECRET=""
BACKEND_GOOGLE_SHEETS_ID=""
BACKEND_MAKE_WEBHOOK_URL=""
# Webhook exclusivo do cenario v2. Nunca reutilize aqui o webhook legado.
BACKEND_MAKE_WEBHOOK_V2_URL=""
# Use `legacy` ate o cenario Make v2 estar configurado e validado no Drive e na planilha.
BACKEND_MAKE_SYNC_MODE="legacy"
BACKEND_GEMINI_API_KEY=""
BACKEND_SUPERVISOR_USERS=""
BACKEND_PROVISIONAL_SUPERVISORS=""
BACKEND_PROVISIONAL_USERS=""
BLOB_READ_WRITE_TOKEN=""
